# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# Discord webhook URL — legacy fallback alert (no button) used only if the bot
# below isn't configured. Create one via a Discord channel's
# Settings > Integrations > Webhooks.
DISCORD_WEBHOOK_URL=

# Discord bot — posts the interest alert WITH a "Send Confirmation Email"
# button (a plain webhook can't route button clicks anywhere). If both this
# and DISCORD_BOT_TOKEN/DISCORD_CHANNEL_ID are set, the bot takes priority.
# See README "Discord bot" section for setup steps.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Resend API key (resend.com) used to send the acknowledgment email when you
# click "Send Confirmation Email" on a Discord alert. Free tier: 3,000/month.
RESEND_API_KEY=

# From-address for confirmation emails. Requires verifying the domain in
# Resend's dashboard (SPF/DKIM DNS records) before this address can send.
EMAIL_FROM=PreorderCards <admin@preordercards.com>

# Shared secret protecting POST /api/seller/admin/generate-keys (mints new
# seller invite keys against the live DB without needing host shell access).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=
