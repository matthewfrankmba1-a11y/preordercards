# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# Discord webhook URL to receive an alert every time someone registers interest.
# Create one via a Discord channel's Settings > Integrations > Webhooks.
DISCORD_WEBHOOK_URL=

# Resend API key (resend.com) used to send a confirmation email to whoever
# registers with an email address. Free tier: 3,000 emails/month.
RESEND_API_KEY=

# From-address for confirmation emails. Requires verifying the domain in
# Resend's dashboard (SPF/DKIM DNS records) before this address can send.
EMAIL_FROM=PreorderCards <notifications@preordercards.com>
